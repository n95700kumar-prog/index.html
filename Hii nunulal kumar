<!DOCTYPE html>
<html lang="hi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Rupam AI - Model 5</title>
    <style>
        :root { --glow: #ff4757; }
        body { margin: 0; background: #000; overflow: hidden; font-family: sans-serif; touch-action: none; }
        #ui-layer { position: fixed; bottom: 30px; width: 100%; display: flex; flex-direction: column; align-items: center; z-index: 1000; }
        .input-box { display: flex; background: #111; border: 2.5px solid var(--glow); border-radius: 50px; width: 85%; max-width: 400px; box-shadow: 0 0 15px var(--glow); }
        input { flex: 1; background: transparent; border: none; color: #fff; padding: 15px 20px; outline: none; font-size: 16px; }
        button { background: var(--glow); border: none; width: 55px; height: 55px; border-radius: 50%; color: #fff; cursor: pointer; font-size: 20px; }
    </style>
</head>
<body>
<div id="ui-layer">
    <div class="input-box">
        <input type="text" id="userInput" placeholder="Kaise ho Rupam?">
        <button id="sendBtn">❤️</button>
    </div>
</div>
<script type="importmap"> { "imports": { "three": "https://unpkg.com/three@0.160.0/build/three.module.js", "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/" } } </script>
<script type="module">
import * as THREE from 'three';
import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';

const scene = new THREE.Scene();
const camera = new THREE.PerspectiveCamera(35, window.innerWidth / window.innerHeight, 0.1, 1000);
const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.setPixelRatio(window.devicePixelRatio);
document.body.appendChild(renderer.domElement);

scene.add(new THREE.AmbientLight(0xffffff, 4.5));
const light = new THREE.DirectionalLight(0xffffff, 3);
light.position.set(5, 5, 10);
scene.add(light);

let model, head, neck, faceMeshes = [], mouse = { x: 0, y: 0 }, blinkT = 0;

// Naya Model Link Yahan Update Kiya Gaya Hai
new GLTFLoader().load('https://cdn.jsdelivr.net/gh/n95700kumar-prog/Naman@main/model%20(5).glb', (gltf) => {
    model = gltf.scene;
    model.scale.set(2.2, 2.2, 2.2); // Model 5 ke liye scale adjust kiya
    model.position.y = -2.5;
    scene.add(model);
    model.traverse(o => {
        if (o.isBone) {
            if (o.name.toLowerCase().includes("head")) head = o;
            if (o.name.toLowerCase().includes("neck")) neck = o;
        }
        if (o.morphTargetInfluences) faceMeshes.push(o);
    });
});

camera.position.z = 5;

window.addEventListener('pointermove', (e) => {
    mouse.x = (e.clientX / window.innerWidth - 0.5) * 0.4;
    mouse.y = (e.clientY / window.innerHeight - 0.5) * 0.2;
});

function animate() {
    requestAnimationFrame(animate);
    const t = Date.now() * 0.001;
    if(model) {
        model.position.y = -2.5 + Math.sin(t * 1.5) * 0.01; 
        if (head) {
            head.rotation.y = THREE.MathUtils.lerp(head.rotation.y, mouse.x, 0.1);
            head.rotation.x = THREE.MathUtils.lerp(head.rotation.x, -mouse.y, 0.1);
        }
        blinkT++;
        faceMeshes.forEach(mesh => {
            const d = mesh.morphTargetDictionary;
            const inf = mesh.morphTargetInfluences;
            const bL = d['eyeBlinkLeft'] || d['eyeBlink_L'];
            const bR = d['eyeBlinkRight'] || d['eyeBlink_R'];
            if (bL !== undefined && blinkT > 180 && blinkT < 192) { inf[bL] = inf[bR] = 1; }
            else if (bL !== undefined) { inf[bL] = inf[bR] = 0; if(blinkT > 192) blinkT = 0; }
        });
    }
    renderer.render(scene, camera);
}
animate();
</script>
</body>
</html>
